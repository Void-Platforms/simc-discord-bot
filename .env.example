# Discord
DISCORD_TOKEN=
DISCORD_APP_ID=

# Optional. Set to a guild ID to register the /sim command in one server
# (instant, intended for development). Leave unset to register globally
# (intended for production, takes up to an hour to propagate).
# DISCORD_DEV_GUILD_ID=

# Simmit
# Create a Simmit API key at https://dashboard.simmit.com/clients
SIMMIT_SECRET_KEY=

# Battle.net API client. SimulationCraft uses these to resolve the
# armory= directive in the profile. Create one at https://develop.battle.net/access/clients
BNET_CLIENT_ID=
BNET_CLIENT_SECRET=
